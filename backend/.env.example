DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tokenflow
SECRET_KEY=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_ORIGINS=http://localhost:5173
TOKENFLOW_MODELS_DIR=../models
TOKENFLOW_RUNTIME_TIMEOUT_SECONDS=20
TOKENFLOW_RUNTIME_MAX_CONCURRENCY=2
TOKENFLOW_RUNTIME_MAX_QUEUE_LENGTH=16
TOKENFLOW_RUNTIME_MAX_MEMORY_MB=512
TOKENFLOW_RUNTIME_CANCEL_GRACE_MS=250
TOKENFLOW_RUNTIME_TEMP_DIR=./storage/runtime_tmp
TOKENFLOW_RUNTIME_AUDIT_LOG_PATH=./storage/runtime_audit.log
TOKENFLOW_RUNTIME_MAX_SOURCE_CHARS=20000
TOKENFLOW_RUNTIME_MAX_RESOURCE_BYTES=5242880
TOKENFLOW_RUNTIME_MAX_OUTPUT_CHARS=200000
TOKENFLOW_RUNTIME_ALLOWED_IMPORTS=math,json,re,statistics,itertools,functools,collections,datetime,decimal,random,numpy
TOKENFLOW_RUNTIME_ALLOWED_MODELS=
TOKENFLOW_RUNTIME_MODEL_BACKEND=llama-cpp-python
TOKENFLOW_RUNTIME_DEFAULT_MODEL=
TOKENFLOW_RUNTIME_MODEL_CTX=4096
TOKENFLOW_RUNTIME_MODEL_THREADS=4
TOKENFLOW_RUNTIME_VLLM_TENSOR_PARALLEL_SIZE=1
TOKENFLOW_RUNTIME_VLLM_GPU_MEMORY_UTILIZATION=0.9
TOKENFLOW_RUNTIME_VLLM_TRUST_REMOTE_CODE=false
TOKENFLOW_RAG_VECTOR_DIM=256
TOKENFLOW_RAG_CHUNK_SIZE=700
TOKENFLOW_RAG_CHUNK_OVERLAP=120
TOKENFLOW_RAG_DEFAULT_TOP_K=5
TOKENFLOW_RAG_CACHE_TTL_SECONDS=900
